{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-evidence/aep_media_profile_v0_1.schema.json",
  "title": "AEPMediaEvidenceProfileV0_1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "statement_id",
    "timestamp",
    "actor",
    "subject",
    "operation",
    "policy",
    "constraints",
    "time_context",
    "media",
    "provenance",
    "evidence",
    "validation"
  ],
  "properties": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "const": "aep-media-evidence-profile"
        },
        "version": {
          "type": "string",
          "const": "0.1"
        }
      }
    },
    "statement_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "subject_ref",
        "policy_ref",
        "media_refs",
        "evidence_refs",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "policy_ref": {
          "type": "string",
          "minLength": 1
        },
        "media_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "succeeded",
            "failed",
            "declared"
          ]
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "constraint_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "constraint_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "rule"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "rule": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "time_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "source",
        "sync_status",
        "start_utc",
        "end_utc"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "enum": [
            "ptp",
            "system_clock",
            "declared_demo"
          ]
        },
        "sync_status": {
          "type": "string",
          "enum": [
            "synchronized",
            "declared",
            "unknown"
          ]
        },
        "start_utc": {
          "type": "string",
          "format": "date-time"
        },
        "end_utc": {
          "type": "string",
          "format": "date-time"
        },
        "ptp_domain": {
          "type": "integer",
          "minimum": 0
        },
        "grandmaster_id": {
          "type": "string"
        },
        "clock_trace_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "media": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifacts"
      ],
      "properties": {
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "role",
              "path",
              "sha256",
              "mime_type",
              "size_bytes",
              "time_context_ref",
              "container",
              "timing"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "role": {
                "type": "string",
                "enum": [
                  "primary_media",
                  "sidecar_manifest",
                  "clock_trace",
                  "other"
                ]
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "mime_type": {
                "type": "string",
                "minLength": 1
              },
              "size_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "time_context_ref": {
                "type": "string",
                "minLength": 1
              },
              "container": {
                "type": "string",
                "minLength": 1
              },
              "timing": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "prft_declared",
                  "timecode_declared"
                ],
                "properties": {
                  "prft_declared": {
                    "type": "boolean"
                  },
                  "timecode_declared": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "actor_ref",
        "subject_ref",
        "operation_ref",
        "media_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "actor_ref": {
          "type": "string",
          "minLength": 1
        },
        "subject_ref": {
          "type": "string",
          "minLength": 1
        },
        "operation_ref": {
          "type": "string",
          "minLength": 1
        },
        "media_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "c2pa_manifest_ref": {
          "type": "string",
          "minLength": 1
        },
        "claim_generator": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "policy_refs",
        "artifact_refs",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "policy_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "artifact_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "validator",
        "required_checks",
        "expected_result"
      ],
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "expected_result": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        }
      }
    }
  }
}
