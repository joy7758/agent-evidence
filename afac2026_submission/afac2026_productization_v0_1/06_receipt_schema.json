{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joy7758/agent-evidence/afac2026/trps-productization-v0.1/receipt.schema.json",
  "title": "AFAC2026 TRPS Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_id",
    "decision_id",
    "model_version",
    "policy_version",
    "scenario_hash",
    "input_summary",
    "risk_summary",
    "triggered_constraints",
    "gate_decision",
    "human_review_status",
    "final_action",
    "rationale",
    "limitations",
    "reproducibility_hash"
  ],
  "properties": {
    "receipt_id": {
      "type": "string"
    },
    "decision_id": {
      "type": "string"
    },
    "model_version": {
      "type": "string"
    },
    "policy_version": {
      "type": "string"
    },
    "scenario_hash": {
      "type": "string"
    },
    "input_summary": {
      "type": "object"
    },
    "risk_summary": {
      "type": "object"
    },
    "triggered_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gate_decision": {
      "type": "string"
    },
    "human_review_status": {
      "type": "string"
    },
    "final_action": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reproducibility_hash": {
      "type": "string"
    }
  }
}
