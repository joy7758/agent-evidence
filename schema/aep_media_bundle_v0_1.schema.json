{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-evidence/aep_media_bundle_v0_1.schema.json",
  "title": "AEPMediaBundleV0_1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "bundle_id",
    "created_utc",
    "statement",
    "artifacts",
    "validation",
    "summary"
  ],
  "properties": {
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "const": "aep-media-bundle"
        },
        "version": {
          "type": "string",
          "const": "0.1"
        }
      }
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "size_bytes",
        "profile"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "profile": {
          "type": "string",
          "const": "aep-media-evidence-profile@0.1"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "role",
          "path",
          "sha256",
          "size_bytes",
          "mime_type",
          "source_path"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "enum": [
              "primary_media",
              "sidecar_manifest",
              "clock_trace",
              "other"
            ]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "mime_type": {
            "type": "string",
            "minLength": 1
          },
          "source_path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "validator",
        "expected_result"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "validator": {
          "type": "string",
          "minLength": 1
        },
        "expected_result": {
          "type": "string",
          "enum": [
            "pass",
            "fail"
          ]
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
